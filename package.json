{
  "name": "@afixt/apg-react",
  "version": "1.2.0",
  "description": "Accessible React components implementing every pattern in the WAI-ARIA Authoring Practices Guide (APG)",
  "keywords": [
    "react",
    "accessibility",
    "a11y",
    "aria",
    "wai-aria",
    "apg",
    "components",
    "accessible-components",
    "design-system",
    "keyboard-navigation",
    "screen-reader"
  ],
  "author": {
    "name": "Karl Groves",
    "email": "karlgroves@gmail.com",
    "url": "https://www.karlgroves.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AFixt/apg-react.git"
  },
  "bugs": {
    "url": "https://github.com/AFixt/apg-react/issues"
  },
  "homepage": "https://github.com/AFixt/apg-react#readme",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/styles.css",
    "./variables.css": "./components/variables.css"
  },
  "files": [
    "dist",
    "components/variables.css",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:e2e": "jest --config e2e/jest.config.js --runInBand",
    "test:e2e:build": "npm run build-storybook && npm run test:e2e",
    "test:all": "npm test && npm run test:e2e:build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint '**/*.css' --ignore-path .gitignore",
    "stylelint:fix": "stylelint '**/*.css' --ignore-path .gitignore --fix",
    "markdownlint": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "markdownlint:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "dupes": "jscpd",
    "links": "lychee --no-progress '**/*.md'",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;Python-2.0;WTFPL;BlueOak-1.0.0' --excludePrivatePackages --summary",
    "license:report": "license-checker-rseidelsohn --production --csv --out reports/licenses.csv",
    "size": "size-limit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:osv": "osv-scanner --lockfile=package-lock.json",
    "security:semgrep": "semgrep --config=p/javascript --config=p/typescript --config=p/react --config=p/owasp-top-ten --config=p/security-audit --config=p/secrets --error --metrics=off",
    "security:secrets": "gitleaks detect --no-banner",
    "security": "npm-run-all -s security:audit security:osv security:secrets",
    "check": "npm run typecheck && npm run lint && npm run stylelint && npm run format:check && npm run markdownlint",
    "check:all": "npm-run-all -s check test dupes license:check build size security:audit",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@double-great/stylelint-a11y": "3.4.10",
    "@eslint/js": "9.39.4",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@total-typescript/ts-reset": "0.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-jest": "^29.7.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jscpd": "4.0.9",
    "license-checker-rseidelsohn": "4.4.2",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.1",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prop-types": "^15.8.1",
    "puppeteer": "^24.42.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "react-test-renderer": "^18.2.0",
    "rollup": "^4.0.0",
    "rollup-plugin-postcss": "^4.0.0",
    "size-limit": "12.1.0",
    "storybook": "^8.6.18",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-declaration-strict-value": "1.11.1",
    "tsc-files": "1.1.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "8.59.0",
    "vite": "^5.4.21"
  }
}
