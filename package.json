{
  "name": "@afixt/apg-react",
  "version": "1.1.1",
  "description": "Accessible React components implementing every pattern in the WAI-ARIA Authoring Practices Guide (APG)",
  "keywords": [
    "react",
    "accessibility",
    "a11y",
    "aria",
    "wai-aria",
    "apg",
    "components",
    "accessible-components",
    "design-system",
    "keyboard-navigation",
    "screen-reader"
  ],
  "author": {
    "name": "Karl Groves",
    "email": "karlgroves@gmail.com",
    "url": "https://www.karlgroves.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AFixt/apg-react.git"
  },
  "bugs": {
    "url": "https://github.com/AFixt/apg-react/issues"
  },
  "homepage": "https://github.com/AFixt/apg-react#readme",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/styles.css",
    "./variables.css": "./components/variables.css"
  },
  "files": [
    "dist",
    "components/variables.css",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:e2e": "jest --config e2e/jest.config.js --runInBand",
    "test:e2e:build": "npm run build-storybook && npm run test:e2e",
    "test:all": "npm test && npm run test:e2e:build",
    "markdownlint": "markdownlint **/*.md --ignore node_modules"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prop-types": "^15.8.1",
    "puppeteer": "^21.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "react-test-renderer": "^18.2.0",
    "rollup": "^4.0.0",
    "rollup-plugin-postcss": "^4.0.0",
    "storybook": "^8.6.18",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^5.4.21"
  }
}
