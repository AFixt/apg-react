{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node10",
    "ignoreDeprecations": "5.0",
    "lib": ["DOM", "ES2018"],
    "jsx": "react",
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": ["components/**/*.tsx", "index.ts"],
  "exclude": ["node_modules", "dist", "__tests__", "e2e", "**/*.stories.*"]
}
